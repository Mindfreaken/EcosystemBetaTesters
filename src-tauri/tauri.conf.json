{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Ecosystem",
  "version": "0.2.0-beta.6",
  "identifier": "com.ecosystem.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "next build --webpack"
  },
  "app": {
    "windows": [
      {
        "title": "Ecosystem",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://api.github.com/repos/Mindfreaken/ecotesters/releases/latest"
      ],
      "pubkey": "RWRRr2gvROoXXDAGD8I4FxW0CnF6WMjvgmAsm+t6eMTSdJNNKq1t6k5V1"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}