{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "EcoSystem Beta",
  "version": "1.0.0-4",
  "identifier": "com.ecosystem.beta.v2",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "EcoSystem Testers Beta v1.0.0-4",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://api.github.com/repos/Mindfreaken/EcosystemBetaTesters/releases/latest"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZEQTM5NzlENDAxOTk5MTAKUldRUW1SbEFuWmVqL1VYckJUd2hjWlAzTmhyZWg3SlUvUGdZVExtTFNNYU9pUGxYOFlrenR3cEwK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}