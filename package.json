{
  "name": "ecosystem-testers-beta",
  "version": "1.0.0-5",
  "private": true,
  "scripts": {
    "dev": "concurrently -n WEB -c blue \"next dev --webpack\" ",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:BUILD": "npm run tauri:build",
    "tauri": "tauri",
    "riot:ingest:local": "tsx scripts/ingestLolMatchLocal.ts",
    "download:league-assets": "tsx scripts/downloadLeagueAssets.ts",
    "gutenberg:extract": "tsx english_word/scripts/extractGutenbergWords.ts",
    "gutenberg:merge": "tsx english_word/scripts/mergeWordLists.ts",
    "local:process": "tsx english_word/scripts/processLocalCorpus.ts",
    "corpus:process": "tsx english_word/scripts/processTxtTar.ts",
    "wordnet:parse": "tsx english_word/scripts/parseWordNet.ts english_word/english-wordnet-2024.xml.gz english_word/output/wordnet_words.txt",
    "gutenberg:refresh": "tsx english_word/scripts/extractGutenbergWords.ts english_word/gutenberg_generated/txt english_word/output/frequency.tsv && tsx english_word/scripts/parseWordNet.ts english_word/english-wordnet-2024.xml.gz english_word/output/wordnet_words.txt && tsx english_word/scripts/mergeWordLists.ts english_word/englishWords.txt english_word/output/frequency.tsv english_word/output/english_words_pypi.txt english_word/output/wordnet_words.txt english_word/output/aca_words.txt english_word/output/dem_words.txt english_word/output/fic_words.txt english_word/output/news_words.txt && node -e \"require('fs').copyFileSync('english_word/output/englishWords.merged.txt','english_word/englishWords.txt')\" && tsx english_word/scripts/checkNoDupes.ts english_word/englishWords.txt --fix",
    "valorant:scrape": "tsx english_word/scripts/scrapeValorantSitemap.ts d:/ecosystem-mono-db-in-folders/valorant_related_words",
    "valorant:crawl": "tsx english_word/scripts/crawlValorantCollections.ts d:/ecosystem-mono-db-in-folders/valorant_related_words",
    "valorant:terms": "tsx english_word/scripts/scrapeValorantTerminology.ts d:/ecosystem-mono-db-in-folders/valorant_related_words/terminology",
    "valorant:api": "tsx english_word/scripts/scrapeValorantApi.ts d:/ecosystem-mono-db-in-folders/valorant_related_words/api",
    "minecraft:biomes": "tsx nerdle/minecraft_related/fetchBiomes.ts",
    "minecraft:blocks": "tsx nerdle/minecraft_related/fetchBlocks.ts",
    "minecraft:all": "tsx nerdle/minecraft_related/fetchMinecraftData.ts",
    "corpus:upload": "tsx english_word/scripts/uploadCorpusWords.ts",
    "valorant:strip-weapons": "tsx nerdle/valorant_related_words/scripts/stripWeaponsChromasLevels.ts",
    "valorant:extract-names": "tsx nerdle/valorant_related_words/scripts/extractWeaponSkinNames.ts --dedupe",
    "valorant:add-acceptable": "tsx nerdle/valorant_related_words/scripts/addAcceptableVariants.ts"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.21.0",
    "@clerk/elements": "^0.24.13",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@livekit/components-react": "^2.9.14",
    "@livekit/components-styles": "^1.1.6",
    "@mui/icons-material": "^7.3.1",
    "@mui/material": "^7.3.1",
    "@mui/x-charts": "^7.3.1",
    "@radix-ui/react-toast": "^1.2.14",
    "@types/uuid": "^10.0.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "cheerio": "^1.0.0-rc.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.29.3",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "geist": "^1.5.1",
    "livekit-client": "^2.15.4",
    "livekit-server-sdk": "^2.13.2",
    "lucide-react": "^0.539.0",
    "naughty-words": "^1.2.0",
    "next": "^16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-intersection-observer": "^9.16.0",
    "sax": "^1.4.1",
    "tailwind-merge": "^3.3.1",
    "unbzip2-stream": "^1.4.3",
    "unzipper": "^0.11.6",
    "uuid": "^11.1.0",
    "xml2js": "^0.6.2",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/zxcvbn": "^4.4.5",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.20.4",
    "typescript": "^5"
  }
}